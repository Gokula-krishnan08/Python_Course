      "5\n"
     ]
    }
   ],
   "source": [
    "a = [1 , 2 , 3 , 4 , 5]\n",
    "\n",
    "a.sort()\n",
    "\n",
    "print(a[len(a) - 1])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c4d7c078",
   "metadata": {},
   "source": [
    "**Optimized Solution - O(N)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "id": "bcb31c31",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "5\n"
     ]
    }
   ],
   "source": [
    "a = [1 , 2, 3 , 5 , 4]\n",
    "\n",
    "max_ele = a[0]\n",
    "\n",
    "for num in a:\n",
    "    if num > max_ele:\n",
    "        max_ele = num \n",
    "\n",
    "print(max_ele)"
   ]
  },
