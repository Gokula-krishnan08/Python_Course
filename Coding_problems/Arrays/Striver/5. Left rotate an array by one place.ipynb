   "source": [
    "**Brute Force - O(N)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "ef10422a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[2, 3, 4, 5, 1]\n"
     ]
    }
   ],
   "source": [
    "a = [1 ,2 , 3 , 4 , 5]\n",
    "\n",
    "temp = a[0]\n",
    "\n",
    "for i in range(1 , len(a)):\n",
    "    a[i - 1] = a[i]\n",
    "a[-1] = temp \n",
    "\n",
    "print(a)"
   ]
  }
