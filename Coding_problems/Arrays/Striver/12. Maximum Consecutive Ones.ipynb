   "source": [
    "**Optimal Solution - O(N)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2d39c4d2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Maximum Consecutive Ones : 3\n"
     ]
    }
   ],
   "source": [
    "arr = [1 , 1 , 0 , 1 , 1 , 1 , 0 , 1 , 1]\n",
    "n = len(arr)\n",
    "\n",
    "max_count = 0\n",
    "count = 0\n",
    "\n",
    "for num in arr:\n",
    "    if num == 1:\n",
    "        count += 1\n",
    "        max_count = max(max_count , count)\n",
    "    else:\n",
    "        count = 0\n",
    "\n",
    "print(f\"Maximum Consecutive Ones : {max_count}\")"
   ]
  }
 ],
