   "source": [
    "**Brute Solution - O(N)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "b3397054",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Found at 3\n"
     ]
    }
   ],
   "source": [
    "a = [1 , 3 , 2 , 8 , 6]\n",
    "\n",
    "key = 8\n",
    "\n",
    "found = -1\n",
    "\n",
    "for i , val in enumerate(a):\n",
    "    if val == key:\n",
    "        found = i\n",
    "        break\n",
    "\n",
    "if found == -1:\n",
    "    print(\"Not found\")\n",
    "else:\n",
    "    print(f\"Found at {found}\")"
   ]
  },
