   "source": [
    "**Brute Force - O(N)**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "cf4add47",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Array is sorted\n"
     ]
    }
   ],
   "source": [
    "a = [1 , 3 ,5 , 8 , 9]\n",
    "\n",
    "flag = 0\n",
    "\n",
    "for i in range(1 , len(a)):\n",
    "    if a[i] < a[i - 1]:\n",
    "        flag = 1\n",
    "        break\n",
    "\n",
    "if flag == 1:\n",
    "    print(\"Array is not sorted\")\n",
    "else:\n",
    "    print(\"Array is sorted\")\n",
    "            \n"
   ]
  }
 ],
